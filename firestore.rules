rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRequestingUserAdmin() {
      // Check if the requesting user has the 'isAdmin' flag in their profile.
      // This requires a read to another document.
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Rules for User Profiles
    match /users/{userId} {
      // A user can read their own profile. An admin can read any profile.
      allow get: if isOwner(userId) || isRequestingUserAdmin();
      // An admin can list all user profiles for the control panel.
      allow list: if isRequestingUserAdmin();
      // A new user can create their own profile document upon signup.
      // We enforce that they cannot make themselves approved or admin.
      allow create: if isOwner(userId);
      // An admin can update any user profile (e.g., to approve them).
      allow update: if isRequestingUserAdmin();
      // Deletes are disallowed for now to prevent accidental data loss.
      allow delete: if false;
    }

    // Rules for Match Data
    match /matches/{matchId} {
      // Only approved users can create, read, update, or delete match data that they own.
      allow read, write: if isSignedIn() &&
                           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true &&
                           request.resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true;
    }
  }
}
