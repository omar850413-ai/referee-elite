
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'omar850413@gmail.com';
    }

    function isUserApproved() {
      return isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true);
    }
    
    function isRequestingUserAdmin() {
      return isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }

    // Rules for User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isRequestingUserAdmin();
      allow list: if isRequestingUserAdmin();
      allow create: if isOwner(userId) &&
                      request.resource.data.email == request.auth.token.email &&
                      (isSuperAdmin() || (request.resource.data.isAdmin == false && request.resource.data.isApproved == false));
      allow update: if isRequestingUserAdmin() || 
                      (isOwner(userId) && 
                       request.resource.data.isAdmin == resource.data.isAdmin &&
                       request.resource.data.isApproved == resource.data.isApproved);
      allow delete: if isRequestingUserAdmin();
    }

    // Rules for Match Data
    match /matches/{matchId} {
      // Un usuario solo puede leer/escribir sus propios partidos (ownerId == auth.uid)
      // Los administradores pueden leer todos los partidos para supervisión.
      allow read: if isUserApproved() && (resource.data.ownerId == request.auth.uid || isRequestingUserAdmin());
      allow create: if isUserApproved() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isUserApproved() && resource.data.ownerId == request.auth.uid;
      allow delete: if isUserApproved() && resource.data.ownerId == request.auth.uid;
    }
  }
}
