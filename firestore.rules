
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // Admin status is now determined by the logic in the app (use-auth.tsx)
      // and access to the admin panel is controlled by the PrivateRoute.
      // This rule just needs to check if the user is authenticated.
      // The update rule below is the most critical one for security.
      return request.auth != null; 
    }
    
    // User Profiles
    match /users/{userId} {
      // A user can only create their own profile document.
      allow create: if isOwner(userId);

      // A user can read their own profile. Admins can read any profile.
      allow get: if isOwner(userId);
      allow list: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;

      // Only an admin can update the 'approved' status.
      // A user cannot update their own profile.
      allow update: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true && request.resource.data.keys().hasOnly(['approved']);
      
      // Nobody can delete user profiles for now.
      allow delete: if false;
    }
  }
}
