rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // New function to identify the super admin by email
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'omar850413@gmail.com';
    }

    function isUserApproved() {
      // An approved user is the super admin OR a user with isApproved: true in their profile.
      return isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true);
    }
    
    function isRequestingUserAdmin() {
      // The super admin is always an admin. Others must have the flag.
      return isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }

    // Rules for User Profiles
    match /users/{userId} {
      // A user can read their own profile. An admin can read any profile.
      allow get: if isOwner(userId) || isRequestingUserAdmin();
      // An admin can list all user profiles for the control panel.
      allow list: if isRequestingUserAdmin();
      
      // ANY signed-in user can create their OWN profile document...
      allow create: if isOwner(userId) &&
                      // ... and they must provide their own email
                      request.resource.data.email == request.auth.token.email &&
                      // ... BUT if they are NOT the super admin, they CANNOT set isAdmin or isApproved to true.
                      (isSuperAdmin() || (request.resource.data.isAdmin == false && request.resource.data.isApproved == false));

      // An admin can update any user profile (e.g., to approve them). The super admin can update their own.
      allow update: if isRequestingUserAdmin();

      // Deletes are disallowed for now to prevent accidental data loss.
      allow delete: if false;
    }

    // Rules for Match Data
    match /matches/{matchId} {
      // Only approved users can read or write match data.
      allow read, write: if isUserApproved();
    }
  }
}
