
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Allow users to create their own profile upon signup
      allow create: if isOwner(userId);
      // Allow users to read their own profile
      allow get: if isOwner(userId);
      // Allow admins to read any user profile
      allow list, get: if isAdmin();
      // Allow admins to update the 'approved' status of any user
      allow update: if isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approved']);
      // Allow users to update their own profile, but NOT their role or approval status
      allow update: if isOwner(userId) && !('role' in request.resource.data) && !('approved' in request.resource.data);
    }

    // Default deny all other reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
