rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isSuperAdmin() { return isSignedIn() && request.auth.token.email == 'omar850413@gmail.com'; }
    
    function getUserData() { 
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDoc) ? get(userDoc).data : null;
    }
    
    function isFromThisApp() {
      let data = getUserData();
      return isSuperAdmin() || (data != null && data.appId == 'referee-elite');
    }

    function isApproved() { 
      let data = getUserData();
      return isSuperAdmin() || (data != null && data.isApproved == true && data.appId == 'referee-elite'); 
    }
    
    function isAdmin() { 
      let data = getUserData();
      return isSuperAdmin() || (data != null && data.isAdmin == true && data.appId == 'referee-elite'); 
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && request.resource.data.isAdmin == resource.data.isAdmin && request.resource.data.isApproved == resource.data.isApproved);
    }

    match /matches/{matchId} {
      allow read, write: if isSignedIn() && isFromThisApp() && (request.auth.uid == matchId || isAdmin() || isApproved());
    }
  }
}
