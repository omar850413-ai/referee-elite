
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // Admin check relies on the user's document in Firestore.
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // User Profiles
    match /users/{userId} {
      // A user can create their own profile document. This is crucial for the new sign-up flow.
      allow create: if isOwner(userId);

      // A user can read their own profile. Admins can read any profile.
      allow get: if isOwner(userId) || isAdmin();
      
      // Admins can list all users for the management panel.
      allow list: if isAdmin();

      // Only an admin can update the 'approved' status of any user.
      allow update: if isAdmin() && request.resource.data.keys().hasOnly(['approved']);
      
      // Nobody can delete user profiles for now.
      allow delete: if false;
    }
  }
}
