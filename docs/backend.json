
{
  "entities": {
    "MatchState": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MatchState",
      "type": "object",
      "description": "Represents the overall state of a single match per user.",
      "properties": {
        "title": { "type": "string" },
        "scores": { "type": "object", "properties": { "home": { "type": "number" }, "away": { "type": "number" } } },
        "fouls": { "type": "object", "properties": { "home": { "type": "number" }, "away": { "type": "number" } } },
        "timer": { "type": "object" },
        "events": { "type": "array" },
        "teamNames": { "type": "object", "properties": { "home": { "type": "string" }, "away": { "type": "string" } } },
        "matchInfo": { "type": "object" },
        "lineups": { "type": "object" },
        "signatures": { "type": "object" },
        "ownerId": { "type": "string" }
      }
    },
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "isApproved": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "sessionId": { "type": "string" },
        "appId": { "type": "string", "description": "Identificador único: referee-elite" }
      }
    }
  },
  "auth": { "providers": ["email_password"] },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "schema": { "$ref": "#/entities/UserProfile" }, "description": "Perfiles de asesores de Referee Elite." } },
      { "path": "/matches/{matchId}", "definition": { "schema": { "$ref": "#/entities/MatchState" }, "description": "Reportes de partidos individuales." } }
    ]
  }
}
